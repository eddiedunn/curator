# Curator Configuration Example
# Copy this file to curator.env and adjust values as needed

# Network Configuration
CURATOR_HOST=0.0.0.0
CURATOR_PORT=8950

# Service URLs (use container names when running in gpu-services network)
CURATOR_ENGRAM_API_URL=http://engram:8800
CURATOR_TRANSCRIBE_SERVICE_URL=http://transcribe:8720

# Database Configuration
CURATOR_DATABASE_URL=sqlite:////data/curator.db

# Optional: API Key for authentication
# CURATOR_API_KEY=your-api-key-here

# Optional: Logging Level (DEBUG, INFO, WARNING, ERROR)
CURATOR_LOG_LEVEL=INFO
